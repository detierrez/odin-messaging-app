generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        Int    @id @default(autoincrement())
    username  String @unique
    avatarUrl String @default("https://media.muckrack.com/profile/images/2061376/peter-mansell.png.256x256_q100_crop-smart.png")

    sentMessages Message[] @relation("sentMessages")

    greaterIdFriends Friendship[] @relation("lesserIdUserFriendships")
    lesserIdFriends  Friendship[] @relation("greaterIdUserFriendships")

    sentRequests     Request[] @relation("sentRequests")
    receivedRequests Request[] @relation("receivedRequests")

    participations Participation[] @relation("userParticipations")
}

model Message {
    id     Int    @id @default(autoincrement())
    from   User   @relation("sentMessages", fields: [fromId], references: [id])
    fromId Int
    to     Chat   @relation("chatMessages", fields: [toId], references: [id])
    toId   Int
    text   String
}

model Friendship {
    lesserId  Int
    greaterId Int

    lesserIdUser  User @relation("lesserIdUserFriendships", fields: [lesserId], references: [id], onDelete: Cascade)
    greaterIdUser User @relation("greaterIdUserFriendships", fields: [greaterId], references: [id], onDelete: Cascade)

    @@id([lesserId, greaterId])
}

model Request {
    from   User @relation("sentRequests", fields: [fromId], references: [id])
    fromId Int
    to     User @relation("receivedRequests", fields: [toId], references: [id])
    toId   Int

    @@id([fromId, toId])
}

model Chat {
    id        Int      @id @default(autoincrement())
    type      ChatType @default(DIRECT)
    name      String?
    avatarUrl String?

    messages       Message[]       @relation("chatMessages")
    participations Participation[] @relation("chatParticipations")
}

model Participation {
    user   User @relation("userParticipations", fields: [userId], references: [id])
    userId Int
    chat   Chat @relation("chatParticipations", fields: [chatId], references: [id])
    chatId Int
    role   Role @default(MEMBER)

    @@id([userId, chatId])
}

enum Role {
    MEMBER
    ADMIN
}

enum ChatType {
    DIRECT
    GROUP
}
