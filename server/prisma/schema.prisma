generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id          Int     @id @default(autoincrement())
    username    String  @unique
    avatarUrl   String  @default("https://static.vecteezy.com/system/resources/thumbnails/067/451/117/small/avatar-simple-flat-default-user-profile-icon-gender-neutral-person-silhouette-profile-picture-symbol-user-account-dp-sign-best-for-social-media-icons-web-and-app-design-illustration-vector.jpg")
    description String?

    sentMessages     Message[]     @relation("sentMessages")
    sentRequests     Request[]     @relation("sentRequests")
    receivedRequests Request[]     @relation("receivedRequests")
    writeAccesses    WriteAccess[] @relation("UsersWriteAccesses")
    readAccesses     ReadAccess[]  @relation("userReadAccesses")
}

model Request {
    senderId   Int
    receiverId Int

    sender   User @relation("sentRequests", fields: [senderId], references: [id])
    receiver User @relation("receivedRequests", fields: [receiverId], references: [id])

    @@id([senderId, receiverId])
}

model WriteAccess {
    id        Int       @id @default(autoincrement())
    userId    Int
    chatId    Int
    startedAt DateTime  @default(now())
    endedAt   DateTime?
    role      Role      @default(MEMBER)

    user User @relation("UsersWriteAccesses", fields: [userId], references: [id], onDelete: Cascade)
    chat Chat @relation("ChatsWriteAccesses", fields: [chatId], references: [id], onDelete: Cascade)
}

model ReadAccess {
    userId Int
    chatId Int

    user User @relation("userReadAccesses", fields: [userId], references: [id], onDelete: Cascade)
    chat Chat @relation("chatReadAccesses", fields: [chatId], references: [id], onDelete: Cascade)

    @@id([userId, chatId])
}

model Chat {
    id        Int     @id @default(autoincrement())
    name      String?
    avatarUrl String?
    type      Type    @default(DIRECT)

    messages      Message[]     @relation("chatMessages")
    writeAccesses WriteAccess[] @relation("ChatsWriteAccesses")
    readAccesses  ReadAccess[]  @relation("chatReadAccesses")
}

model Message {
    id      Int      @id @default(autoincrement())
    userId  Int
    chatId  Int
    content String
    sentAt  DateTime @default(now())

    user User @relation("sentMessages", fields: [userId], references: [id])
    chat Chat @relation("chatMessages", fields: [chatId], references: [id], onDelete: Cascade)
}

enum Type {
    DIRECT
    GROUP
}

enum Role {
    MEMBER
    ADMIN
}
