generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id       Int    @id @default(autoincrement())
    username String @unique

    sent     Message[] @relation(name: "sent")
    received Message[] @relation(name: "received")

    lessIdFriends    Friendship[] @relation("lessIdFriendships")
    greaterIdFriends Friendship[] @relation("greaterIdFriendships")

    sentRequests     Request[] @relation("sentRequests")
    receivedRequests Request[] @relation("receivedRequests")
}

model Message {
    id     Int    @id @default(autoincrement())
    from   User   @relation(name: "sent", fields: [fromId], references: [id])
    fromId Int
    to     User   @relation(name: "received", fields: [toId], references: [id])
    toId   Int
    text   String
}

model Friendship {
    lesserId  Int
    greaterId Int

    lesserIdUser  User @relation("lessIdFriendships", fields: [lesserId], references: [id], onDelete: Cascade)
    greaterIdUser User @relation("greaterIdFriendships", fields: [greaterId], references: [id], onDelete: Cascade)

    @@id([lesserId, greaterId])
}

model Request {
    id     Int  @id @default(autoincrement())
    from   User @relation(name: "sentRequests", fields: [fromId], references: [id])
    fromId Int
    to     User @relation(name: "receivedRequests", fields: [toId], references: [id])
    toId   Int
}
