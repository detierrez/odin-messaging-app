generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  avatarUrl String?

  sentMessages     Message[]    @relation("sentMessages")
  greaterIdFriends Friendship[] @relation("lesserIdUserFriendships")
  lesserIdFriends  Friendship[] @relation("greaterIdUserFriendships")
  sentRequests     Request[]    @relation("sentRequests")
  receivedRequests Request[]    @relation("receivedRequests")
  memberships      Membership[] @relation("userMemberships")
}

model Friendship {
  lesserId  Int
  greaterId Int

  lesserIdUser  User  @relation("lesserIdUserFriendships", fields: [lesserId], references: [id], onDelete: Cascade)
  greaterIdUser User  @relation("greaterIdUserFriendships", fields: [greaterId], references: [id], onDelete: Cascade)
  chat          Chat? @relation("chatFriendship")

  @@id([lesserId, greaterId])
}

model Group {
  id        Int     @id @default(autoincrement())
  name      String?
  avatarUrl String?

  memberships Membership[] @relation("groupMemberships")
  chat        Chat?        @relation("chatGroup")
}

model Membership {
  userId  Int
  groupId Int
  role    Role @default(MEMBER)

  user  User  @relation("userMemberships", fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation("groupMemberships", fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Request {
  senderId   Int
  receiverId Int

  sender   User @relation("sentRequests", fields: [senderId], references: [id])
  receiver User @relation("receivedRequests", fields: [receiverId], references: [id])

  @@id([senderId, receiverId])
}

model Message {
  id     Int    @id @default(autoincrement())
  userId Int
  chatId Int
  text   String

  user User @relation("sentMessages", fields: [userId], references: [id])
  chat Chat @relation("chatMessages", fields: [chatId], references: [id], onDelete: Cascade)
}

model Chat {
  id                  Int  @id @default(autoincrement())
  lesserFriendshipId  Int?
  greaterFriendshipId Int?
  groupId             Int? @unique

  messages   Message[]   @relation("chatMessages")
  friendship Friendship? @relation("chatFriendship", fields: [lesserFriendshipId, greaterFriendshipId], references: [lesserId, greaterId], onDelete: Cascade)
  group      Group?      @relation("chatGroup", fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([lesserFriendshipId, greaterFriendshipId])
}

enum Role {
  MEMBER
  ADMIN
}
